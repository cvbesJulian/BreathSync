{
  "data": {
    "dataset_dir": "../../datasets/melody_chord",
    "songs_csv": "songs.csv",
    "source": "combined",
    "sources": ["pop909", "nottingham", "openbook"],
    "vocab_path": "artifacts/combined/vocab.json",
    "splits_path": "artifacts/combined/splits.json",
    "checkpoint_dir": "artifacts/combined/checkpoints"
  },
  "vocab": {
    "min_count": 20
  },
  "windows": {
    "lengths_bars": [0.5, 1.0, 1.5, 2.0, 3.0, 4.0],
    "length_weights": [0.15, 0.25, 0.10, 0.25, 0.10, 0.15],
    "hold_target_frac": 0.5,
    "grid": "beat"
  },
  "features": {
    "dt_bucket_edges_geomspace": {"start": 0.5, "stop": 36.0, "num_edges": 23},
    "dur_bucket_edges_geomspace": {"start": 0.25, "stop": 8.0, "num_edges": 7},
    "octave_base_pitch": 48,
    "octave_buckets": 4,
    "phase_bins": 12,
    "max_bar_offset": 4,
    "max_seq_len": 64,
    "meters": [2, 3, 4, 5, 6, 9]
  },
  "augment": {
    "note_dropout": 0.10,
    "ornament_dropout": 0.15,
    "ornament_max_dur": 0.5,
    "octave_shift_prob": 0.20,
    "minor_oversample": 1
  },
  "model": {
    "d_model": 128,
    "n_layers": 3,
    "n_heads": 4,
    "ff_dim": 256,
    "dropout": 0.2,
    "label_smoothing": 0.05,
    "bigru_layers": 2,
    "bigru_hidden": 128
  },
  "train": {
    "batch_size": 256,
    "lr": 3e-4,
    "weight_decay": 0.05,
    "warmup_steps": 500,
    "max_epochs": 24,
    "early_stop_patience": 5,
    "func_loss_weight": 0.3,
    "class_weight_clamp": [0.5, 4.0],
    "seed": 42
  },
  "splits": {
    "ratios": [0.8, 0.1, 0.1],
    "seed": 42
  }
}
